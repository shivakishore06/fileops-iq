# ===========================================================
# FileOps IQ — Environment Configuration
# Copy this file to .env and fill in the values
# ===========================================================

# ---- Database ----
DATABASE_URL="postgresql://fileops_user:fileops_password@localhost:5432/fileops_db?schema=public"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT Authentication ----
# REQUIRED: Change these in production! Use: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---- Encryption ----
# REQUIRED: Must be exactly 32 bytes for AES-256
ENCRYPTION_KEY=32bytekeyforaesencryptionhere!!!

# ---- Server ----
APP_PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ---- Logging ----
LOG_LEVEL=info
# LOG_FORMAT=json  # Use 'json' for production (CloudWatch/Datadog/ELK compatible)

# ---- MinIO / Object Storage ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=fileops-bucket

# ---- AI / Copilot ----
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o

# ---- Email / SMTP (for email alerts) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fileops-iq.com

# ---- Feature Flags (Defaults) ----
FF_AI_COPILOT=true
FF_RETENTION_ENGINE=true
FF_FILE_EXPLORER=true
